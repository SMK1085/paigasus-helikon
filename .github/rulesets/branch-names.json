{
  "name": "branch-names",
  "target": "branch",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "include": ["~ALL"],
      "exclude": [
        "refs/heads/main",
        "refs/heads/feature/**",
        "refs/heads/hotfix/**"
      ]
    }
  },
  "bypass_actors": [
    { "actor_id": "DEPENDABOT_APP_ID", "actor_type": "Integration", "bypass_mode": "always" },
    { "actor_id": 3742291,             "actor_type": "Integration", "bypass_mode": "always" }
  ],
  "rules": [
    { "type": "creation" },
    { "type": "update" },
    { "type": "deletion" }
  ]
}
